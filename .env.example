# Copy this to .env.local and fill in your values

# Anthropic (for /api/chat fallback)
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vapi — handles voice conversation end-to-end (STT + LLM + TTS + turn-taking)
# Get at: https://dashboard.vapi.ai/ → Account → Public Key
# Free $10 credit on signup — covers hours of conversation
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key_here
